+    def _tree_eager_attn(self, q, k, v, tm):
+        """Eager combined-mask attention for DDTree verification (D11).
+        Each spec query node attends to ALL context (gathered from the paged KV
+        cache) plus its tree ancestors. Single SDPA, GQA-aware. Returns the
+        attn output [nq, num_heads*head_dim], or None to fall back to self.attn.
+        """
+        try:
+            fc = _get_forward_context()
+            am = fc.attn_metadata[self.attn.layer_name]
+            seq_len = int(am.seq_lens[0].item())
+            bt = getattr(am, "block_table_tensor", None)
+            if bt is None:
+                bt = getattr(am, "block_table", None)
+            if bt is None:
+                return None
+            nq = q.shape[0]
+            ctx_len = seq_len - nq
+            if ctx_len < 0:
+                return None
+            H, Hkv, D = self.num_heads, self.num_kv_heads, self.head_dim
+            kv_cache = self.attn.kv_cache  # [2, num_blocks, block_size, Hkv, D]
+            if not hasattr(kv_cache, "shape") or kv_cache.numel() == 0:
+                return None
+            key_cache, val_cache = kv_cache[0], kv_cache[1]
+            bs = key_cache.shape[1]
+            dev = q.device
+
+            Q = q.view(nq, H, D)
+            spec_k = k.view(nq, Hkv, D)
+            spec_v = v.view(nq, Hkv, D)
+            if ctx_len > 0:
+                idx = torch.arange(ctx_len, device=dev)
+                blk = bt[0, (idx // bs)].long()
+                off = (idx % bs).long()
+                ctx_k = key_cache[blk, off].to(Q.dtype)  # [ctx_len, Hkv, D]
+                ctx_v = val_cache[blk, off].to(Q.dtype)
+                K = torch.cat([ctx_k, spec_k], dim=0)
+                V = torch.cat([ctx_v, spec_v], dim=0)
+            else:
+                K, V = spec_k, spec_v
+            L = K.shape[0]
+
+            # Ancestor mask over the spec region: flat pos i -> node i+1.
+            parent = tm.tree_parent_index
+            B = len(parent)
+            # Flat query pos i == tree node i (pos 0 == root). Node i attends to
+            # its ancestors (and itself); padding positions (>= B) attend to self.
+            anc = torch.zeros(nq, nq, dtype=torch.bool, device=dev)
+            for i in range(nq):
+                if i >= B:  # padding token: self-only
+                    anc[i, i] = True
+                    continue
+                j = i
+                while j != -1:
+                    if 0 <= j < nq:
+                        anc[i, j] = True
+                    j = parent[j]
+            mask = torch.zeros(nq, L, dtype=torch.bool, device=dev)
+            if ctx_len > 0:
+                mask[:, :ctx_len] = True
+            mask[:, ctx_len:] = anc
+
+            Qs = Q.permute(1, 0, 2).unsqueeze(0)   # [1, H, nq, D]
+            Ks = K.permute(1, 0, 2).unsqueeze(0)   # [1, Hkv, L, D]
+            Vs = V.permute(1, 0, 2).unsqueeze(0)
