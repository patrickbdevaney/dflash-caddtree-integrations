+def _find_accepted_leaf(tree, path_tokens, node_to_slot):
+    """Walk the DDTree following accepted path tokens; return the leaf node's
+    pool slot, or None if no path node was accepted (only the bonus)."""
+    n = len(tree.parent_index)
+    children: list[list[int]] = [[] for _ in range(n)]
+    for i in range(1, n):
+        children[tree.parent_index[i]].append(i)
+    current = 0
+    for tok in path_tokens:
+        nxt = None
+        for c in children[current]:
+            if tree.token_ids[c] == tok:
+                nxt = c
+                break
+        if nxt is None:
+            break
+        current = nxt
+    if current == 0 or current >= len(node_to_slot):
+        return None
+    return node_to_slot[current]
+
