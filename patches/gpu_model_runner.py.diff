+    def _get_gdn_state_pool(self):
+        """Return the shared GDN ssm_state pool (kv_cache[1]) of the first GDN
+        layer, for DDTree branch-state promotion. Cached after first lookup."""
+        pool = getattr(self, "_gdn_state_pool", None)
+        if pool is not None:
+            return pool
+        for module in self.model.modules():
+            mt = getattr(module, "mamba_type", None)
+            kvc = getattr(module, "kv_cache", None)
+            if mt and "gdn" in str(mt).lower() and kvc is not None:
+                try:
+                    self._gdn_state_pool = kvc[1]
+                    return self._gdn_state_pool
+                except Exception:
+                    continue
+        self._gdn_state_pool = None
+        return None
+
