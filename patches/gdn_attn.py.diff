+        if (
+            self.tree_mode
+            and cur_tree is not None
+            and num_spec_decodes > 0
+            and spec_state_indices_tensor is not None
+        ):
+            dev = spec_state_indices_tensor.device
+            row0 = spec_state_indices_tensor[0]
+            ncols = row0.shape[0]
+            ssize = min(cur_tree.size, ncols)
+            # Canonical (prior accepted) state lives at slot[num_accepted-1]
+            # (same convention as linear DFlash). Root maps there; the other
+            # nodes take the remaining slots. Promotion writes the accepted
+            # leaf back to slot[num_accepted-1] so the existing align machinery
+            # carries it to the next round (handles buffer rotation for us).
+            ca = 0
+            if num_accepted_tokens is not None:
+                ca = int(num_accepted_tokens[0].item()) - 1
+            ca = max(0, min(ca, ncols - 1))
+            avail = [j for j in range(ncols) if j != ca]
+            node_to_slot = [0] * ssize
+            node_to_slot[0] = int(row0[ca].item())  # root = canonical
+            for k, node in enumerate(range(1, ssize)):
+                node_to_slot[node] = int(row0[avail[k]].item())
+            drafter.current_node_to_slot = node_to_slot
+            drafter.current_spec_slots = [int(x) for x in row0.tolist()]
+            # Group non-root nodes by BFS depth; flat position of node i is i-1.
+            from collections import defaultdict as _dd
+            by_depth = _dd(list)
+            for i in range(1, ssize):
+                by_depth[cur_tree.depth[i]].append(i)
+            tree_flat_pos, tree_node_slots, tree_parent_slots = [], [], []
+            for d in sorted(by_depth):
+                nodes_d = by_depth[d]
