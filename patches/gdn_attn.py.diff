+                        dtype=torch.int32, device=dev,
+                    )
+                )
+                tree_parent_slots.append(
+                    torch.tensor(
+                        [node_to_slot[cur_tree.parent_index[i]] for i in nodes_d],
+                        dtype=torch.int32, device=dev,
+                    )
+                )
+            tree_num_nodes = ssize - 1
+            tree_mode = True
